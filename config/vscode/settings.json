{
  // ── Editor ────────────────────────────────────────────────────────────────
  "editor.fontFamily": "JetBrainsMono Nerd Font",
  "editor.fontSize": 13.5,
  "editor.fontWeight": "400",
  "editor.lineHeight": 1.5,
  "editor.lineNumbers": "relative",
  "editor.cursorStyle": "line",
  "editor.cursorBlinking": "solid",
  "editor.renderLineHighlight": "gutter",
  "editor.scrollBeyondLastLine": false,
  "editor.wordWrap": "on",
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.minimap.enabled": false,
  "editor.inlineSuggest.enabled": false,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.stickyScroll.enabled": true,
  "editor.suggest.preview": false,

  // ── Files ─────────────────────────────────────────────────────────────────
  "files.autoSave": "onFocusChange",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,

  // ── Theme ─────────────────────────────────────────────────────────────────
  // Install "Nightfox Theme" from the VSCode marketplace (search "Nightfox")
  "workbench.colorTheme": "Nightfox",
  "workbench.preferredDarkColorTheme": "Nightfox",
  "workbench.preferredLightColorTheme": "Dayfox",
  "window.autoDetectColorScheme": true,

  // ── Workbench ─────────────────────────────────────────────────────────────
  "workbench.editor.openSideBySideDirection": "right",
  "workbench.startupEditor": "none",
  "breadcrumbs.enabled": true,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,

  // ── Vim ───────────────────────────────────────────────────────────────────
  "vim.leader": "<space>",
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.useSystemClipboard": true,
  "vim.useCtrlKeys": true,
  "vim.ignorecase": true,
  "vim.smartcase": true,
  "vim.camelCaseMotion.enable": true,
  "vim.highlightedyank.enable": true,
  "vim.highlightedyank.duration": 150,
  "vim.foldfix": true,
  "vim.statusBarColorControl": false,
  "vim.normalModeKeyBindingsNonRecursive": [
    // clear search highlight — mirrors <Esc> -> nohlsearch
    { "before": ["<Esc>"], "commands": [":nohl"] },

    // file ops — mirrors nvim leader bindings
    {
      "before": ["<leader>", "w"],
      "commands": ["workbench.action.files.save"],
    },
    {
      "before": ["<leader>", "x"],
      "commands": ["workbench.action.closeActiveEditor"],
    },
    {
      "before": ["<leader>", "Q"],
      "commands": ["workbench.action.closeAllEditors"],
    },

    // pane navigation — mirrors C-h/j/k/l window moves
    // Ctrl+J from editor goes to terminal (terminal is the "below" pane)
    { "before": ["<C-h>"], "commands": ["workbench.action.focusLeftGroup"] },
    { "before": ["<C-l>"], "commands": ["workbench.action.focusRightGroup"] },
    { "before": ["<C-k>"], "commands": ["workbench.action.focusAboveGroup"] },
    { "before": ["<C-j>"], "commands": ["workbench.action.terminal.focus"] },

    // file finder / search
    {
      "before": ["<leader>", "f", "f"],
      "commands": ["workbench.action.quickOpen"],
    },
    {
      "before": ["<leader>", "f", "g"],
      "commands": ["workbench.action.findInFiles"],
    },

    // explorer & git
    {
      "before": ["<leader>", "e"],
      "commands": ["workbench.action.toggleSidebarVisibility"],
    },
    { "before": ["<leader>", "g", "s"], "commands": ["workbench.view.scm"] },

    // diagnostics
    {
      "before": ["<leader>", "p"],
      "commands": ["workbench.actions.view.problems"],
    },

    // LSP
    { "before": ["<leader>", "r"], "commands": ["editor.action.rename"] },
    {
      "before": ["<leader>", "c", "a"],
      "commands": ["editor.action.quickFix"],
    },
  ],

  // ── Terminal ──────────────────────────────────────────────────────────────
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.lineHeight": 0.8,
  "terminal.integrated.fontWeight": "300",
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.copyOnSelection": true,

  // ── Search ────────────────────────────────────────────────────────────────
  "search.smartCase": true,

  // ── TypeScript / JavaScript ───────────────────────────────────────────────
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.preferences.importModuleSpecifier": "relative",
  "js/ts.inlayHints.parameterNames.enabled": "literals",
  "js/ts.inlayHints.variableTypes.enabled": false,

  // ── Language formatters ───────────────────────────────────────────────────
  "[javascript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[javascriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[typescriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[html]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[css]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "workbench.editor.showTabs": "none",
  "window.commandCenter": false,
  "workbench.activityBar.compact": true,
  "claudeCode.preferredLocation": "panel",
  "chat.disableAIFeatures": true,
  "typescript.experimental.useTsgo": true,
}
